NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Service role key — server-side only, NEVER expose in client code.
# Used to bypass table-level privilege checks when upserting the artist row.
# Find it in Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional admin guards used by dashboard/admin access checks.
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_UID=00000000-0000-0000-0000-000000000000

# Server-side admin checks for the approval API route.
ADMIN_EMAIL=admin@example.com
ADMIN_UID=00000000-0000-0000-0000-000000000000

# Optional Google Calendar sync (server-side).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Transactional email via Resend (https://resend.com).
# Without these, email sending is silently skipped — bookings/approvals/rejections still work.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=MissMay Tattoos <noreply@yourdomain.com>
