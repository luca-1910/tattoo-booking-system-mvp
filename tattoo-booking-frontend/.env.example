NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Optional admin guards used by dashboard/admin access checks.
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_UID=00000000-0000-0000-0000-000000000000

# Server-side admin checks for the approval API route.
ADMIN_EMAIL=admin@example.com
ADMIN_UID=00000000-0000-0000-0000-000000000000

# Optional Google Calendar sync (server-side).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
